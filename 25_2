def f(n):
    r = []
    for d in range(1,n):
        if n % d == 0:
            if d % 10 == 7 and d != 7 and d != n:
                r.append(d)
    return sorted(r)

a = []
b = []
for n in range(700000+1,10**9):
    r = f(n)
    if len(r) > 0:
        a.append(n)
        b.append(r[0])
    if len(a) == 5:
        break
print(a)
