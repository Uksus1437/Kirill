# max(m) -> (int) максимальное число
# min(m) -> (int) минимальное число
# sorted(m) -> (list) сортировка по возрастанию
# sum(m) -> (int) сумма элементов массива
# len(m) -> количество элементов в массиве
# m.count(x) -> (int) количество элементов x в массиве


'''Откройте файл электронной таблицы, содержащей в каждой строке пять натуральных чисел.

Определите количество строк таблицы, в которых квадрат суммы максимального и минимального
чисел в строке больше суммы квадратов трёх оставшихся.
'''
f = open('9.txt').readlines()
c = 0
for i in f:                     # i = '52\t65\t1\t20\t15\n'
    i = i.split('\t')           # i = ['52', '65', '1', '20', '15\n']
    i = list(map(int, i))       # i = [52, 65, 1, 20, 15]
    i = sorted(i)               # i = [1, 15, 20, 52, 65]
    if (i[0] + i[4]) ** 2 > (i[1]**2 + i[2]**2 + i[3]**2):
        c += 1
print(c)
    

'''B каждой строке электронной таблицы записаны пять целых положительных чисел. 
Определите, сколько в таблице строк, для которых выполнены следующие условия:

— все числа в строке различны;
— нечётных чисел больше, чем чётных;
— сумма нечётных чисел меньше суммы чётных.

B ответе запишите число — количество строк, для которых выполнены эти условия.
'''
f = open('9.txt').readlines()
c = 0
for i in f:
    i = i.split('\t')
    i = list(map(int, i))               # i = [1, 2, 4, 3, 5]
    x = set(i)
    chet = [s for s in i if s%2==0]     # chet = [2, 4]
    nchet =[s for s in i if s%2!=0]     # chet = [1, 3, 5]
    if len(x)==5:
        if len(chet)<len(nchet):
            if sum(chet)>sum(nchet):
                c += 1
print(c)



"""Откройте файл электронной таблицы, содержащей в каждой строке четыре натуральных числа.

Определите количество строк таблицы, содержащих числа, для которых выполнены оба условия:

—  наибольшее из 4 чисел меньше суммы трёх других;
—  все четыре числа различны.
      0   1  2   3
i = [12, 32, 43, 54]
"""

f = open("9.txt").readlines()
c = 0
for i in f:
    i = i.split("\t")
    i = list(map(int, i))
    i = sorted(i)
    if i[3] < (i[0] + i[1] + i[2]):
        if len(set(i)) == 4:
            c += 1
print(c)


